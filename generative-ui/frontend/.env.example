# Backend API URL
VITE_API_BASE_URL=http://localhost:8000

# Enable AI-powered entity matching (optional)
# Set to 'true' to enable LLM-based entity matching for complex cases
# Default: false (uses fast keyword-based detection instead)
# Note: Requires backend to be running with /api/match-entity endpoint
VITE_ENABLE_AI_MATCHING=false
